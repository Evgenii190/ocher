# Режим окружения для docker compose: dev | prod
#   dev  — поднимается только локальная Postgres, приложение запускается через `bun run dev`
#   prod — собирается и запускается Next.js, подключение к удалённой БД
COMPOSE_PROFILES=dev

# --- Подключение к БД ---
# dev:  локальная база из docker compose (db на localhost:5432)
# prod: строка подключения к УДАЛЁННОЙ базе
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ochko

# Секрет Payload — сгенерируй случайную строку (например: openssl rand -hex 32)
PAYLOAD_SECRET=change-me

# Секрет для сброса кэша контактов (POST /api/revalidate/site-contacts)
REVALIDATE_SECRET=change-me-too

# --- Параметры локальной БД (используются только профилем dev) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ochko
POSTGRES_PORT=5432

# Порт, на котором слушает приложение в prod
PORT=3000

# --- Сидирование каталога (`bun run seed`) ---
# Учётные данные администратора, создаваемого при первом запуске seed.
SEED_ADMIN_EMAIL=admin@ochko.local
SEED_ADMIN_PASSWORD=changeme123
