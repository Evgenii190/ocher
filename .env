# Режим окружения для docker compose: dev | prod
# COMPOSE_PROFILES=prod
COMPOSE_PROFILES=dev

# DATABASE_URL=postgresql://user:Ufogub98@192.168.0.4:5432/default_db?sslmode=no-verify
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ochko

# Секрет Payload — обязательно замени на случайную строку перед prod
PAYLOAD_SECRET=abcdefghijklmnopqrstuvwxyz0123456789adasdadgfdagagfadg

# Параметры локальной БД (профиль dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ochko
POSTGRES_PORT=5433

PORT=3000